# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-SUPABASE-PROJECT].supabase.co:5432/postgres"

# Next Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-strong-secret-key-here"

# Redis (Upstash)
REDIS_URL="rediss://default:YOUR-PASSWORD@YOUR-ENDPOINT.upstash.io:25368"

# Cloudflare R2
NEXT_PUBLIC_R2_URL="https://YOUR-PUBLIC-R2-URL.r2.dev"
R2_ACCESS_KEY_ID="your_access_key"
R2_SECRET_ACCESS_KEY="your_secret_key"
R2_ACCOUNT_ID="your_account_id"

# Payments integration (Razorpay)
RAZORPAY_KEY_ID="your_razorpay_key"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# Emails
RESEND_API_KEY="re_123456789"
